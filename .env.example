# ─── Render va seta PORT automat, nu-l pune manual ───
# PORT=4000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/magura?retryWrites=true&w=majority

# JWT — schimbă cu un string random lung în producție
JWT_SECRET=schimba_cu_un_string_random_foarte_lung
JWT_EXPIRES_IN=7d

# Contul de admin (folosit de setup-admin.js)
ADMIN_EMAIL=admin@magura.ro
ADMIN_PASSWORD=ParolaForte123!

# CORS — pune domeniile reale după deploy
# Lasă gol în development (permite orice)
# Exemple producție:
# ALLOWED_ORIGINS=https://magura.ro,https://www.magura.ro,https://magura-admin.netlify.app
ALLOWED_ORIGINS=

# Email notificări contact (opțional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=contact@magura.ro
# SMTP_PASS=parola_app_gmail
# EMAIL_TO=admin@magura.ro
